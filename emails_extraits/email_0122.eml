       =20
        body {
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
            color: #333;
            background-color: #f7fafc;
            margin: 0;
            padding: 0;
        }
        .email-container {
            max-width: 600px;
            margin: 30px auto;
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }
        .header {
            background: linear-gradient(135deg, #0070BA 0%, #003087 100%);
            color: white;
            padding: 30px;
            text-align: center;
            position: relative;
        }
        .header:after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 4px;
            background: #FFC439;
            border-radius: 2px;
        }
        h1 {
            margin: 20px 0 0;
            font-size: 28px;
            font-weight: 700;
        }
        .logo {
            height: 40px;
        }
        .content {
            padding: 30px;
        }
        .status-card {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
            border-left: 4px solid #0070BA;
        }
        .status-item {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
        }
        .status-icon {
            color: #00C165;
            font-weight: bold;
            margin-right: 10px;
            font-size: 20px;
        }
        .alert-box {
            background: #FFF8E6;
            border: 1px solid #FFEBB2;
            border-radius: 8px;
            padding: 16px;
            margin: 25px 0;
        }
        .cta-button {
            display: inline-block;
            background: #0070BA;
            color: white;
            font-weight: 600;
            padding: 12px 24px;
            border-radius: 6px;
            text-decoration: none;
            margin: 10px 0;
            transition: all 0.2s ease;
        }
        .cta-button:hover {
            background: #005EA6;
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(0, 112, 186, 0.2);
        }
        .phone-number {
            font-weight: 700;
            color: #D30A2B;
            font-size: 20px;
            letter-spacing: 0.5px;
            text-decoration: none;
        }
        .features {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin: 25px 0;
        }
        .feature-item {
            background: #F5F7FA;
            padding: 12px;
            border-radius: 6px;
            font-size: 14px;
        }
        .footer {
            text-align: center;
            padding: 20px;
            background: #F5F7FA;
            color: #666;
            font-size: 13px;
        }
        .divider {
            height: 1px;
            background: linear-gradient(to right, transparent, #E5E7EB, tra=
nsparent);
            margin: 25px 0;
        }
