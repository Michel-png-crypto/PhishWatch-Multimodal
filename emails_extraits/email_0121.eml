            font-weight: 600;
            padding: 12px 25px;
            border-radius: 30px;
            text-decoration: none;
            margin: 10px 0;
            transition: all 0.3s ease;
            font-size: 16px;
        }
        .phone-link:hover {
            background: #004b8d;
            transform: translateY(-2px);
            box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);
        }
        .phone-number {
            font-weight: 700;
            color: #d82c20;
            font-size: 20px;
            letter-spacing: 0.5px;
        }
        .footer {
